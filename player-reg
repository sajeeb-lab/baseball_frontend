            <option value="">Select position…</option>
            <option value="OF">OF — Outfield</option>
            <option value="CINF">CINF — Corner Infield</option>
            <option value="MIF">MIF — Middle Infield</option>
            <option value="C">C — Catcher</option>
            <option value="RHP">RHP — Right-Handed Pitcher</option>
            <option value="LHP">LHP — Left-Handed Pitcher</option>
          </select>
        </div>

        <div class="field">
          <label>Second Position</label>
          <select id="pos-2">
            <option value="">Select position…</option>
            <option value="OF">OF — Outfield</option>
            <option value="CINF">CINF — Corner Infield</option>
            <option value="MIF">MIF — Middle Infield</option>
            <option value="C">C — Catcher</option>
            <option value="RHP">RHP — Right-Handed Pitcher</option>
            <option value="LHP">LHP — Left-Handed Pitcher</option>
