    <div class="err-msg" id="err-1"></div>
    <button class="btn btn-primary" onclick="goToPage2()">
      Continue &nbsp;→
    </button>

  </div><!-- /page-1 -->

  <!-- ════════════ PAGE 2: PLAYER INFO ════════════ -->
  <div class="page" id="page-2">

    <div class="progress-bar"><div class="progress-fill" style="width:66%"></div></div>

    <div class="card">
      <div class="card-head">
        <div class="icon">⚾</div>
        <h2>Player Info</h2>
      </div>
      <div class="card-body">
        <p class="req-note"><span>★</span> indicates a required field</p>

        <div class="field">
          <label>Player Date of Birth <span class="req">★</span></label>
          <input type="date" id="player-dob">
        </div>

        <div class="field">
          <label>Player Cell</label>
          <input type="tel" id="player-cell" placeholder="(555) 000-0000">
        </div>

        <div class="field">
