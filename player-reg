    </div>

    <div class="err-msg" id="err-2"></div>
    <button class="btn btn-primary" onclick="goToPage3()">
      Continue to Payment &nbsp;→
    </button>

  </div><!-- /page-2 -->

  <!-- ════════════ PAGE 3: PAYMENT ════════════ -->
  <div class="page" id="page-3">

    <div class="progress-bar"><div class="progress-fill" style="width:100%"></div></div>

    <div class="card" id="payment-card">
      <div class="card-head">
        <div class="icon">💳</div>
        <h2>Payment</h2>
      </div>
      <div class="card-body">

        <div class="notice">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#b88a00" stroke-width="1.5"/><path d="M8 5v4M8 11v.5" stroke="#b88a00" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span>Review your registration details before completing payment. Your spot is secured once payment is received.</span>
        </div>

        <!-- Summary -->
        <div class="section-label">Registration Summary</div>
        <div style="background:var(--light);border-radius:6px;padding:1rem 1.2rem;margin-bottom:1.2rem;font-size:.85rem;line-height:2">
          <div><strong>Team:</strong> <span id="sum-team">—</span></div>
          <div><strong>Player:</strong> <span id="sum-player">—</span></div>
          <div id="sum-fee-row"><strong>Amount:</strong> <span id="sum-fee">—</span></div>
        </div>

        <div id="payment-action">
          <!-- Filled by JS depending on payment type -->
        </div>

        <div class="err-msg" id="err-3"></div>

      </div>
    </div>

    <!-- Success -->
    <div class="success-screen" id="success-screen">
      <div class="success-icon">✅</div>
      <h2>Registration Complete!</h2>
      <p>Thank you for registering. Your information has been submitted successfully.<br>You will receive a confirmation email shortly.</p>
    </div>

  </div><!-- /page-3 -->

</div><!-- /main -->

<script>
// ── CONFIG ────────────────────────────────────────────────────────────────
const API_BASE = 'https://backend-baseball-inky.vercel.app';

// ── STATE ─────────────────────────────────────────────────────────────────
let selectedTeam    = null;   // { _id, teamName, state, location, ageGroup }
let teamFinancials  = null;   // { player_fee, deposit_enabled, deposit_amount, monthly_payments, … }
let createdPlayerId = null;
let createdPaymentId= null;
let currentPage     = 1;

// ── TEAM SEARCH ───────────────────────────────────────────────────────────
let allTeams = [];

async function loadAllTeams() {
  try {
    const r = await fetch(`${API_BASE}/api/teams`);
    const d = await r.json();
    allTeams = d.teams || [];
  } catch(e) {
    console.warn('Could not preload teams', e);
  }
}
loadAllTeams();

function searchTeams() {
  const q = document.getElementById('team-search-input').value.trim().toLowerCase();
  const resultsEl = document.getElementById('search-results');
  if (!q) { resultsEl.style.display = 'none'; return; }

  const matches = allTeams.filter(t => t.teamName.toLowerCase().includes(q));
  if (!matches.length) {
    resultsEl.innerHTML = '<div class="search-result-item"><span>No teams found for that name.</span></div>';
    resultsEl.style.display = 'block';
    return;
  }
  resultsEl.innerHTML = matches.map(t => `
    <div class="search-result-item" onclick="selectTeam('${t._id}')">
      <strong>${t.teamName}</strong>
      <span>${[t.location, t.state, t.ageGroup].filter(Boolean).join(' · ')}</span>
    </div>`).join('');
  resultsEl.style.display = 'block';
}

document.getElementById('team-search-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') searchTeams();
});

async function selectTeam(id) {
  selectedTeam = allTeams.find(t => t._id === id);
  document.getElementById('search-results').style.display = 'none';
  document.getElementById('selected-team-name').textContent = selectedTeam.teamName;
  document.getElementById('selected-team-badge').style.display = 'flex';
  document.getElementById('team-search-input').style.display = 'none';
  document.querySelector('.search-btn').style.display = 'none';

  // Fetch financials
  try {
    const r = await fetch(`${API_BASE}/api/teams/${id}/financials`);
    const d = await r.json();
    teamFinancials = d.financials;
    renderFeeDisplay();
  } catch(e) {
    teamFinancials = null;
  }
}

function renderFeeDisplay() {
  const fd = document.getElementById('fee-display');
  if (!teamFinancials) { fd.style.display = 'none'; return; }

  const { player_fee, deposit_enabled, deposit_amount, monthly_payments } = teamFinancials;
  fd.style.display = 'block';

  if (deposit_enabled) {
    document.getElementById('fee-label').textContent = 'Deposit Due Today';
    document.getElementById('fee-amount').textContent = `$${deposit_amount || 0}`;
    document.getElementById('fee-type-badge').textContent = 'Deposit';
  } else if (!monthly_payments) {
    document.getElementById('fee-label').textContent = 'Full Payment Due';
    document.getElementById('fee-amount').textContent = `$${player_fee || 0}`;
    document.getElementById('fee-type-badge').textContent = 'Full Payment';
  } else {
    // monthly only – show nothing
    fd.style.display = 'none';
  }
}

function clearTeam() {
  selectedTeam = null;
  teamFinancials = null;
  document.getElementById('selected-team-badge').style.display = 'none';
  document.getElementById('team-search-input').style.display = '';
  document.querySelector('.search-btn').style.display = '';
  document.getElementById('team-search-input').value = '';
  document.getElementById('fee-display').style.display = 'none';
}

// ── PAGE NAVIGATION ───────────────────────────────────────────────────────
function setPage(n) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(`page-${n}`).classList.add('active');
  currentPage = n;
  // Step dots
  for (let i = 1; i <= 3; i++) {
    const dot = document.getElementById(`step-dot-${i}`);
    dot.classList.remove('active', 'completed');
    if (i < n) dot.classList.add('completed');
    else if (i === n) dot.classList.add('active');
  }
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function showErr(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg;
  el.style.display = 'block';
  el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
function hideErr(id) { document.getElementById(id).style.display = 'none'; }

function getRadio(name) {
  const el = document.querySelector(`input[name="${name}"]:checked`);
  return el ? el.value : '';
}

function goToPage2() {
  hideErr('err-1');

  if (!selectedTeam) return showErr('err-1', 'Please search for and select your team before continuing.');
  if (!v('player-name')) return showErr('err-1', 'Player Name is required.');
  if (!v('father-first')) return showErr('err-1', 'Father First Name is required.');
  if (!v('father-last')) return showErr('err-1', 'Father Last Name is required.');
  if (!v('father-cell')) return showErr('err-1', 'Father Cell is required.');
  if (!v('father-email')) return showErr('err-1', 'Father Email is required.');

  const acks = ['ack1','ack2','ack3','ack4','ack5'];
  for (const a of acks) {
    if (!getRadio(a)) return showErr('err-1', 'Please answer all acknowledgement questions before continuing.');
  }

  setPage(2);
}

function goToPage3() {
  hideErr('err-2');

  if (!v('player-dob')) return showErr('err-2', 'Player Date of Birth is required.');
  if (!v('addr-street')) return showErr('err-2', 'Street address is required.');
  if (!v('addr-city')) return showErr('err-2', 'City is required.');
  if (!v('addr-state')) return showErr('err-2', 'State is required.');
  if (!v('addr-zip')) return showErr('err-2', 'Zip Code is required.');
  if (!getRadio('bats')) return showErr('err-2', 'Please select Bats (Right or Left).');
  if (!getRadio('throws')) return showErr('err-2', 'Please select Throws (Right or Left).');
  if (!vs('pos-1')) return showErr('err-2', 'First Position is required.');
  if (!vs('grad-year')) return showErr('err-2', 'Graduation Year is required.');
  if (!v('high-school')) return showErr('err-2', 'High School is required.');

  buildPaymentPage();
  setPage(3);
}

function v(id) { return document.getElementById(id).value.trim(); }
function vs(id) { return document.getElementById(id).value; }

// ── BUILD PAYMENT PAGE ────────────────────────────────────────────────────
function buildPaymentPage() {
  document.getElementById('sum-team').textContent   = selectedTeam?.teamName || '—';
  document.getElementById('sum-player').textContent = v('player-name') || '—';

  const actionEl = document.getElementById('payment-action');

  if (!teamFinancials) {
    document.getElementById('sum-fee-row').style.display = 'none';
    actionEl.innerHTML = `<button class="btn btn-navy" onclick="submitRegistration('none')">Complete Registration</button>`;
    return;
  }

  const { player_fee, deposit_enabled, deposit_amount, monthly_payments } = teamFinancials;

  if (deposit_enabled) {
    document.getElementById('sum-fee').textContent = `$${deposit_amount} deposit (full fee: $${player_fee})`;
    actionEl.innerHTML = `<button class="btn btn-primary" onclick="submitAndPay('deposit')">Pay $${deposit_amount} Deposit &nbsp;→</button>`;
  } else if (!monthly_payments) {
    document.getElementById('sum-fee').textContent = `$${player_fee}`;
    actionEl.innerHTML = `<button class="btn btn-primary" onclick="submitAndPay('full')">Pay $${player_fee} Now &nbsp;→</button>`;
  } else {
    // monthly only – no payment redirect
    document.getElementById('sum-fee-row').style.display = 'none';
    actionEl.innerHTML = `<button class="btn btn-navy" onclick="submitRegistration('none')">Complete Registration</button>`;
  }
}

// ── SUBMIT ────────────────────────────────────────────────────────────────
async function submitRegistration(paymentType) {
  hideErr('err-3');
  const btn = document.querySelector('#payment-action button');
  btn.disabled = true;
  btn.textContent = 'Submitting…';

  try {
    // 1. Create player on roster
    const playerBody = {
      name:      v('player-name'),
      jersey:    v('jersey-1') || '',
      gradYear:  vs('grad-year'),
      position:  vs('pos-1'),
      hw:        v('hw'),
      city:      v('addr-city'),
      state:     v('addr-state'),
      email:     v('player-email'),
      cell:      v('player-cell'),
    };

    const pr = await fetch(`${API_BASE}/api/teams/${selectedTeam._id}/roster`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(playerBody),
    });
    const pd = await pr.json();
    if (!pr.ok) throw new Error(pd.message || 'Failed to create player record');
    createdPlayerId = pd.player?._id;

    // 2. Create payment record
    const fee     = teamFinancials?.player_fee     || 0;
    const deposit = teamFinancials?.deposit_amount || 0;

    const pymBody = {
      coachId:         selectedTeam._id,
      playerId:        createdPlayerId,
      playerName:      v('player-name'),
      totalFee:        fee,
      depositAmount:   deposit,
      balance:         fee,
      registeredDate:  new Date().toISOString().split('T')[0],
      paymentDeadline: teamFinancials?.payment_deadline || '',
    };

    const pymr = await fetch(`${API_BASE}/api/coach/player-payments`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(pymBody),
    });
    const pymd = await pymr.json();
    if (!pymr.ok) throw new Error(pymd.message || 'Failed to create payment record');
    createdPaymentId = pymd.payment?._id;

    return createdPaymentId;

  } catch (err) {
    btn.disabled = false;
    btn.textContent = 'Try Again';
    showErr('err-3', err.message || 'Something went wrong. Please try again.');
    return null;
  }
}

async function submitAndPay(paymentType) {
  const paymentId = await submitRegistration(paymentType);
  if (!paymentId) return;

  // 3. Create Stripe checkout session
  try {
    const origin = window.location.href;
    const cr = await fetch(`${API_BASE}/api/checkout`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        coachId:         selectedTeam._id,
        paymentType,
        playerPaymentId: paymentId,
        successUrl:      origin + (origin.includes('?') ? '&' : '?') + 'payment=success',
        cancelUrl:       origin + (origin.includes('?') ? '&' : '?') + 'payment=cancelled',
      }),
    });
    const cd = await cr.json();
    if (!cr.ok) throw new Error(cd.message || 'Failed to create checkout session');
    window.location.href = cd.url;
  } catch(err) {
    document.getElementById('err-3').textContent = err.message;
    document.getElementById('err-3').style.display = 'block';
    const btn = document.querySelector('#payment-action button');
    btn.disabled = false;
    btn.textContent = 'Try Again';
  }
}

// Handle no-payment flow (monthly only)
document.querySelectorAll('#payment-action').forEach(() => {});
// Wrap no-payment submit
window.submitRegistration = async function(type) {
  const paymentId = await _submitRegistration(type);
  if (!paymentId) return;
  // Show success
  document.getElementById('payment-card').style.display = 'none';
  document.getElementById('success-screen').style.display = 'block';
};

// internal
async function _submitRegistration(paymentType) {
  hideErr('err-3');
  const btn = document.querySelector('#payment-action button');
  btn.disabled = true;
  btn.textContent = 'Submitting…';

  try {
    const playerBody = {
      name:      v('player-name'),
      jersey:    v('jersey-1') || '',
      gradYear:  vs('grad-year'),
      position:  vs('pos-1'),
      hw:        v('hw'),
      city:      v('addr-city'),
      state:     v('addr-state'),
      email:     v('player-email'),
      cell:      v('player-cell'),
    };

    const pr = await fetch(`${API_BASE}/api/teams/${selectedTeam._id}/roster`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(playerBody),
    });
    const pd = await pr.json();
    if (!pr.ok) throw new Error(pd.message || 'Failed to create player record');
    createdPlayerId = pd.player?._id;

    const fee     = teamFinancials?.player_fee     || 0;
    const deposit = teamFinancials?.deposit_amount || 0;

    const pymBody = {
      coachId:         selectedTeam._id,
      playerId:        createdPlayerId,
      playerName:      v('player-name'),
      totalFee:        fee,
      depositAmount:   deposit,
      balance:         fee,
      registeredDate:  new Date().toISOString().split('T')[0],
      paymentDeadline: teamFinancials?.payment_deadline || '',
    };

    const pymr = await fetch(`${API_BASE}/api/coach/player-payments`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(pymBody),
    });
    const pymd = await pymr.json();
    if (!pymr.ok) throw new Error(pymd.message || 'Failed to create payment record');
    createdPaymentId = pymd.payment?._id;

    return createdPaymentId;

  } catch(err) {
    const btn = document.querySelector('#payment-action button');
    if (btn) { btn.disabled = false; btn.textContent = 'Try Again'; }
    showErr('err-3', err.message || 'Something went wrong. Please try again.');
    return null;
  }
}

// Re-wire submitAndPay to use _submitRegistration
window.submitAndPay = async function(paymentType) {
  hideErr('err-3');
  const btn = document.querySelector('#payment-action button');
  if (btn) { btn.disabled = true; btn.textContent = 'Processing…'; }

  const paymentId = await _submitRegistration(paymentType);
  if (!paymentId) return;

  try {
    const origin = window.location.href.split('?')[0];
    const cr = await fetch(`${API_BASE}/api/checkout`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        coachId:         selectedTeam._id,
        paymentType,
        playerPaymentId: paymentId,
        successUrl:      origin + '?payment=success',
        cancelUrl:       origin + '?payment=cancelled',
      }),
    });
    const cd = await cr.json();
    if (!cr.ok) throw new Error(cd.message || 'Failed to create checkout session');
    window.location.href = cd.url;
  } catch(err) {
    showErr('err-3', err.message);
    const b = document.querySelector('#payment-action button');
    if (b) { b.disabled = false; b.textContent = 'Try Again'; }
  }
};

// ── HANDLE PAYMENT RETURN ─────────────────────────────────────────────────
(function() {
  const params = new URLSearchParams(window.location.search);
  if (params.get('payment') === 'success') {
    setPage(3);
    document.getElementById('payment-card').style.display = 'none';
    document.getElementById('success-screen').style.display = 'block';
  }
})();
</script>
</body>
